APP_ENV=local
APP_URL=http://localhost:5173
API_URL=http://localhost:3000
BACKEND_PUBLIC_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:8000,http://localhost:5173

JWT_SECRET=local-dev-secret-change-before-production
JWT_EXPIRES_IN=1h
JWT_REMEMBER_EXPIRES_IN=30d
PASSWORD_RESET_TOKEN_TTL_MINUTES=30
REQUEST_BODY_LIMIT=1mb
UPLOADS_DIR=uploads

DB_HOST=localhost
DB_PORT=55432
DB_NAME=aiforge
DB_USER=aiforge
DB_PASSWORD=aiforge_password
DATABASE_URL=postgresql://aiforge:aiforge_password@localhost:55432/aiforge?schema=public

# SMTP server of the email account that will send reset-password links.
# Gmail: smtp.gmail.com
# Mail.ru: smtp.mail.ru
# Yandex: smtp.yandex.ru
SMTP_HOST=

# Use 587 with SMTP_SECURE=false, or 465 with SMTP_SECURE=true.
SMTP_PORT=587
SMTP_SECURE=false

# Full email address that will send reset-password links.
# Example: SMTP_USER=your-email@gmail.com
SMTP_USER=

# App password / SMTP password for SMTP_USER.
# For Gmail, use Google App Password, not your normal account password.
SMTP_PASS=

# Sender shown in reset-password emails.
# Example: MAIL_FROM=your-email@gmail.com
# Or: MAIL_FROM="AI Cinema Lab" <your-email@gmail.com>
MAIL_FROM=

# Gemini API key for Cinema Bot.
# Create a free key in Google AI Studio and paste it here.
GEMINI_API_KEY=

# Default free-tier friendly model for project chat.
GEMINI_MODEL=gemini-2.5-flash

# Google OAuth credentials for "Sign in with Google".
# Create them in Google Cloud Console -> APIs & Services -> Credentials.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Must exactly match the authorized redirect URI in Google Cloud Console.
# Local example: http://localhost:3000/api/auth/google/callback
# Production example: https://aicinema.213.155.21.121.sslip.io/api/auth/google/callback
GOOGLE_OAUTH_REDIRECT_URI=
