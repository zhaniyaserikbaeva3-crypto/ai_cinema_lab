{
  "name": "aiforge-backend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:prod": "node dist/main.js",
    "build": "nest build",
    "test": "npm run test:e2e",
    "test:e2e": "jest --config ./tests/jest-e2e.json --runInBand",
    "test:e2e:db": "npm run db:migrate:test && DATABASE_URL=postgresql://aiforge:aiforge_password@localhost:55432/aiforge_test?schema=public JWT_SECRET=test-secret JWT_EXPIRES_IN=1h UPLOADS_DIR=uploads-test BACKEND_PUBLIC_URL=http://localhost:3000 jest --config ./tests/jest-db-e2e.json --runInBand",
    "db:up": "docker compose -f ../docker-compose.yml up -d postgres",
    "db:down": "docker compose -f ../docker-compose.yml down",
    "db:reset": "docker compose -f ../docker-compose.yml down -v",
    "db:migrate": "DATABASE_URL=postgresql://aiforge:aiforge_password@localhost:55432/aiforge?schema=public prisma migrate deploy",
    "db:migrate:test": "DATABASE_URL=postgresql://aiforge:aiforge_password@localhost:55432/aiforge_test?schema=public prisma migrate deploy",
    "prisma:generate": "prisma generate"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.15",
    "@nestjs/core": "^10.4.15",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/platform-express": "^10.4.15",
    "@prisma/client": "^6.19.3",
    "bcryptjs": "^2.4.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "dotenv": "^17.4.2",
    "nodemailer": "^8.0.8",
    "prisma": "^6.19.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.8",
    "@nestjs/schematics": "^10.2.3",
    "@nestjs/testing": "^10.4.15",
    "@types/bcryptjs": "^2.4.6",
    "@types/jest": "^29.5.14",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.10.2",
    "@types/nodemailer": "^8.0.0",
    "@types/supertest": "^6.0.2",
    "jest": "^29.7.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.2"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": ".",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "src/**/*.(t|j)s"
    ],
    "testEnvironment": "node"
  }
}
