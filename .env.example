# Docker Compose defaults.
# Copy to .env only if you need to override local ports or production URLs.

APP_ENV=production
APP_URL=http://localhost:8080
API_URL=http://localhost:3000
BACKEND_PUBLIC_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:8080,http://localhost:8000,http://localhost:5173

POSTGRES_DB=aiforge
POSTGRES_USER=aiforge
POSTGRES_PASSWORD=aiforge_password
POSTGRES_PORT=55432

FRONTEND_PORT=8080
FRONTEND_HTTPS_PORT=8443
BACKEND_PORT=3000
RUN_MIGRATIONS=true
